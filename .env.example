# Copy to .env, fill in real values.

# OpenRouter - https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...

# Route claude-code / codex through OpenRouter.
# ANTHROPIC base has NO /v1 (SDK appends /v1/messages); OPENAI base HAS /v1.
ANTHROPIC_API_KEY=${OPENROUTER_API_KEY}
ANTHROPIC_BASE_URL=https://openrouter.ai/api
OPENAI_API_KEY=${OPENROUTER_API_KEY}
OPENAI_BASE_URL=https://openrouter.ai/api/v1

# Daytona - preferred cloud sandbox. https://app.daytona.io
# Requires: pipx inject harbor daytona
DAYTONA_API_KEY=dtn_...
# DAYTONA_TARGET=us

# E2B - avoid: free tier 1h cap, Harbor hardcodes 24h → 400.
# E2B_API_KEY=e2b_...

# Apify - https://console.apify.com/settings/integrations
# Forwarded into the agent container via [environment.env] in tasks/apify-*/task.toml.
APIFY_TOKEN=apify_api_...

# Later
# GITHUB_TOKEN=ghp_...
